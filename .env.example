# Optional: Hugging Face (higher rate limits for model download). Unauthenticated works but may warn.
# HF_TOKEN=

# ── STT (faster-whisper) ──
# Model: tiny.en (fastest) | base.en (balanced) | small.en (accurate)
JARVIS_FW_MODEL=base.en
# Device: cuda | cpu  (if cuda fails at runtime, Jarvis reloads on CPU once)
JARVIS_FW_DEVICE=cuda
# Compute: float16 (GPU) | int8
JARVIS_FW_COMPUTE=float16
# Used for CPU: int8 (default) or float32 — also used after auto GPU→CPU fallback
JARVIS_FW_COMPUTE_CPU=int8

# ── LLM (Ollama) ──
# e.g. qwen2.5:3b | llama3.2:3b | qwen2.5:7b
JARVIS_OLLAMA_MODEL=qwen2.5:3b

# ── TTS (Edge) ──
# en-GB-ThomasNeural: formal UK male, Jarvis-like. Alternatives: en-GB-RyanNeural, en-US-ChristopherNeural
JARVIS_EDGE_VOICE=en-GB-ThomasNeural
# Slightly calmer by default; raise rate for snappier delivery
JARVIS_EDGE_RATE=+10%
JARVIS_EDGE_PITCH=+2Hz
# Whole reply in one Edge request if under this many characters (reduces pauses between sentences)
JARVIS_TTS_SINGLE_MAX_CHARS=4000

# ── Behaviour ──
JARVIS_WAKE_ON_CLAP=0
JARVIS_MAX_TURNS=12

# ── Coding lab (voice: "set up my lab" — no LLM) ──
# Base directory when you use a name only (e.g. "project demo" under ~/code/demo)
# JARVIS_LAB_BASE=%USERPROFILE%\code
# JARVIS_LAB_DEFAULT_NAME=python-lab
# JARVIS_LAB_VENV=1
# If `code` is not on PATH: full path to code.cmd
# JARVIS_VSCODE_PATH=
